{
  "name": "video-hls-backend",
  "private": true,
  "scripts": {
    "dev:api": "nodemon --config nodemon.json src/server.ts",
    "dev:worker": "nodemon --config nodemon.json src/worker.ts",
    "build": "tsc",
    "start:api": "node -r tsconfig-paths/register dist/server.js",
    "start:worker": "node -r tsconfig-paths/register dist/worker.js"
  },
  "dependencies": {
    "@tus/file-store": "^2.1.0",
    "@tus/server": "^2.4.1",
    "bullmq": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "fluent-ffmpeg": "^2.1.2",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.19",
    "@types/fluent-ffmpeg": "^2.1.2",
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}
